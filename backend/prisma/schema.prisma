generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum Role {
  USHER
  ADMIN
  SUPER_ADMIN
}

enum Unit {
  USHER
  DRAMA
  MEDIA
  CHOIR
  TECHNICAL
  ACADEMIC
  BIBLE_STUDY
  BROTHERS
  EVANGELISM
  PRAYER
  PROTOCOL
  SISTERS
  WELFARE
  EDITORIAL
  OTHER
}

enum TaskType {
  SCANNER
  ARRANGER
}

enum EventStatus {
  UPCOMING
  SIGN_IN_ACTIVE
  SYNCING_PHASE
  SIGN_OUT_ACTIVE
  COMPLETED
  ARCHIVED
}

enum ScanType {
  SIGN_IN
  SIGN_OUT
}

// --- MODELS ---

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  first_name    String?  // NEW: Optional first name
  last_name     String?  // NEW: Optional last name
  role          Role     @default(USHER)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  last_active   DateTime @default(now())
  unit          Unit     @default(USHER)

  // Relations
  events_created    Event[]            @relation("EventCreator")
  scans_recorded    AttendanceRecord[] @relation("ScanUsher")
  unlocked_events   EventAccess[]
  assignments       Assignment[]
  push_subscriptions PushSubscription[]
}

model Student {
  matric_number String  @id 
  first_name    String? // The '?' makes this optional (nullable in the database)
  last_name     String? 
  department    String?
  level         Int?    

  // Relations
  attendance_records AttendanceRecord[]
}

model Event {
  id          String      @id @default(uuid())
  name        String
  description String?
  date        DateTime
  status      EventStatus @default(UPCOMING)
  is_archived Boolean     @default(false)
  created_at  DateTime    @default(now())
  unlock_pin  String      @unique @default(cuid())
  assignments Assignment[]
  
  created_by_id String
  created_by    User        @relation("EventCreator", fields: [created_by_id], references: [id])

  // Relations
  records     AttendanceRecord[]
  unlocked_bg EventAccess[]
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  scan_type     ScanType
  scanned_at    DateTime // Time captured on the phone
  synced_at     DateTime @default(now()) // Time inserted into DB

  // Foreign Keys
  event_id      String
  matric_number String
  usher_id      String

  // Relations
  event         Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [matric_number], references: [matric_number])
  usher         User     @relation("ScanUsher", fields: [usher_id], references: [id])

  // DELIVERABLE 2: The database-level constraint preventing double scans.
  // A student can only have ONE sign_in and ONE sign_out per event.
  @@unique([event_id, matric_number, scan_type])
}

model EventAccess {
  id          String   @id @default(uuid())
  user_id     String
  event_id    String
  unlocked_at DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id]) // An usher only needs to unlock an event once
}

// Represents the physical columns in the chapel
model Zone {
  id          String  @id @default(uuid())
  name        String  @unique // e.g., "A1", "CHOIR & MEDIA"
  prefix      String  // e.g., "A", "CHOIR" - used to group contiguous blocks
  is_default  Boolean @default(true) // Marks the base case columns
}

// Maps who is doing what, where, and for which event
model Assignment {
  id          String   @id @default(uuid())
  user_id     String
  event_id    String
  zone_name   String   // The specific column, e.g., "A1"
  task_type   TaskType // SCANNER or ARRANGER
  is_primary  Boolean  @default(true) // true for high-traffic, false for secondary rest columns
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id, zone_name]) // A user can't be assigned to the exact same column twice in one event
}

// Stores browser endpoints for Web Push Notifications
model PushSubscription {
  id         String   @id @default(uuid())
  user_id    String
  endpoint   String   @unique
  p256dh     String   // Cryptographic key from the browser
  auth       String   // Auth token from the browser
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}